{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oridesign.local/schemas/m0f/runtime-limits-v1.schema.json",
  "title": "OriDesign M0F runtime limits v1",
  "description": "Candidate or measured runtime limits. Candidate values are hypotheses, not supported-input limits.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "schemaId", "profileId", "status", "profileHash", "limits"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "schemaId": { "const": "https://oridesign.local/schemas/m0f/runtime-limits-v1.schema.json" },
    "profileId": { "type": "string", "pattern": "^[a-z][a-z0-9.-]{0,127}$" },
    "status": { "enum": ["candidate", "frozen"] },
    "profileHash": {
      "anyOf": [{ "type": "null" }, { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }]
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxProjectFileBytes",
        "maxFoldFileBytes",
        "maxEvidenceBlobBytes",
        "maxVertices",
        "maxEdges",
        "maxFaces",
        "maxStringCodeUnits",
        "maxJsonDepth",
        "maxGridColumns",
        "maxGridRows",
        "maxHistoryBytes",
        "maxWorkerMessageBytes",
        "maxWorkerCancelResponseMs",
        "maxInputDecimalDigits",
        "minNormalizedFeature",
        "maxNormalizedLengthRatio",
        "maxPaperAspectRatio",
        "maxTreeDegree"
      ],
      "properties": {
        "maxProjectFileBytes": { "$ref": "#/$defs/limit" },
        "maxFoldFileBytes": { "$ref": "#/$defs/limit" },
        "maxEvidenceBlobBytes": { "$ref": "#/$defs/limit" },
        "maxVertices": { "$ref": "#/$defs/limit" },
        "maxEdges": { "$ref": "#/$defs/limit" },
        "maxFaces": { "$ref": "#/$defs/limit" },
        "maxStringCodeUnits": { "$ref": "#/$defs/limit" },
        "maxJsonDepth": { "$ref": "#/$defs/limit" },
        "maxGridColumns": { "$ref": "#/$defs/limit" },
        "maxGridRows": { "$ref": "#/$defs/limit" },
        "maxHistoryBytes": { "$ref": "#/$defs/limit" },
        "maxWorkerMessageBytes": { "$ref": "#/$defs/limit" },
        "maxWorkerCancelResponseMs": { "$ref": "#/$defs/limit" },
        "maxInputDecimalDigits": { "$ref": "#/$defs/limit" },
        "minNormalizedFeature": { "$ref": "#/$defs/limit" },
        "maxNormalizedLengthRatio": { "$ref": "#/$defs/limit" },
        "maxPaperAspectRatio": { "$ref": "#/$defs/limit" },
        "maxTreeDegree": { "$ref": "#/$defs/limit" }
      },
      "$comment": "parseRuntimeLimitsV1 additionally fixes the unit and integer/real kind for each key."
    }
  },
  "$defs": {
    "limit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit",
        "candidates",
        "selected",
        "measurementStatus",
        "measurementRef",
        "rejectionReasonCode"
      ],
      "properties": {
        "unit": {
          "enum": [
            "bytes",
            "count",
            "code-units",
            "levels",
            "milliseconds",
            "decimal-digits",
            "normalized-length",
            "ratio"
          ]
        },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "number", "exclusiveMinimum": 0 }
        },
        "selected": {
          "anyOf": [{ "type": "null" }, { "type": "number", "exclusiveMinimum": 0 }]
        },
        "measurementStatus": { "enum": ["pending", "measured"] },
        "measurementRef": {
          "anyOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
        },
        "rejectionReasonCode": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9.-]{2,127}$"
        }
      }
    }
  },
  "$comment": "Frozen-profile completeness and hash recomputation are fail-closed runtime checks."
}
