                "artifactId": { "const": "source-select-tree-decimal-digits" },
                "path": { "const": "select-tree-decimal-digits.json" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/negativeArtifactTemplate" },
            {
              "type": "object",
              "properties": {
                "artifactId": { "const": "source-select-tree-length-ratio" },
                "path": { "const": "select-tree-length-ratio.json" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/negativeArtifactTemplate" },
            {
              "type": "object",
              "properties": {
                "artifactId": { "const": "source-select-grid-columns" },
                "path": { "const": "select-grid-columns.json" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/negativeArtifactTemplate" },
            {
              "type": "object",
              "properties": {
                "artifactId": { "const": "source-select-grid-quantization-error" },
                "path": { "const": "select-grid-quantization-error.json" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/negativeArtifactTemplate" },
            {
              "type": "object",
              "properties": {
                "artifactId": { "const": "source-select-fold-max-vertices" },
                "path": { "const": "select-fold-max-vertices.json" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/negativeArtifactTemplate" },
            {
              "type": "object",
              "properties": {
                "artifactId": { "const": "source-premature-evidence" },
                "path": { "const": "premature-evidence.json" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/negativeArtifactTemplate" },
            {
              "type": "object",
              "properties": {
                "artifactId": { "const": "source-method-mismatch" },
                "path": { "const": "method-mismatch.json" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/negativeArtifactTemplate" },
            {
              "type": "object",
              "properties": {
                "artifactId": { "const": "source-unknown-solver-key" },
                "path": { "const": "unknown-solver-key.json" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/negativeArtifactTemplate" },
            {
              "type": "object",
