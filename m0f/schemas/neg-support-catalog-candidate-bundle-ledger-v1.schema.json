                "artifactId": { "const": "source-unsorted-candidates" },
                "path": { "const": "unsorted-candidates.json" }
              }
            }
          ]
        }
      ],
      "items": false
    }
  },
  "$defs": {
    "artifactBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactId",
        "role",
        "path",
        "mediaType",
        "sha256",
        "licenseSpdx",
        "provenance"
      ],
      "properties": {
        "artifactId": { "type": "string" },
        "role": { "type": "string" },
        "path": { "type": "string" },
        "mediaType": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "licenseSpdx": { "const": "MIT" },
        "provenance": { "type": "object" }
      }
    },
    "authoredProvenance": {
      "const": {
        "sourceReferenceId": "oridesign-neg-support-catalog-candidates-v1",
        "sourceUse": "project-authored",
        "derivation": "authored",
        "dependsOnArtifactIds": []
      }
    },
    "mutationProvenance": {
      "const": {
        "sourceReferenceId": "oridesign-neg-support-catalog-candidates-v1",
        "sourceUse": "project-authored",
        "derivation": "mutated-from-control",
        "dependsOnArtifactIds": ["control-support-profile-candidate-catalog"]
      }
    },
    "readmeArtifact": {
      "allOf": [
        { "$ref": "#/$defs/artifactBase" },
        {
          "type": "object",
          "properties": {
            "artifactId": { "const": "bundle-readme" },
            "role": { "const": "readme" },
            "path": { "const": "README.md" },
            "mediaType": { "const": "text/markdown; charset=utf-8" },
            "provenance": { "$ref": "#/$defs/authoredProvenance" }
          }
        }
      ]
    },
    "controlArtifact": {
      "allOf": [
        { "$ref": "#/$defs/artifactBase" },
        {
          "type": "object",
          "properties": {
            "artifactId": { "const": "control-support-profile-candidate-catalog" },
            "role": { "const": "accepted-control" },
            "path": { "const": "control-support-profile-candidate-catalog.json" },
            "mediaType": { "const": "application/json" },
            "provenance": { "$ref": "#/$defs/authoredProvenance" }
          }
        }
      ]
    },
    "negativeArtifactTemplate": {
      "allOf": [
        { "$ref": "#/$defs/artifactBase" },
        {
          "type": "object",
          "properties": {
            "role": { "const": "negative-source" },
            "mediaType": { "const": "application/json" },
            "provenance": { "$ref": "#/$defs/mutationProvenance" }
          }
        }
      ]
    }
  }
}
