{
  "name": "oridesign",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A local-first origami design Web/PWA.",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "npm run lint:eslint && npm run format:check",
    "lint:eslint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:m0f-worker": "playwright test --config=playwright.m0f.config.ts --project=chromium",
    "test:e2e:m0f-worker:matrix": "playwright test --config=playwright.m0f.config.ts",
    "test:golden": "vitest run tests/golden",
    "test:perf": "vitest bench tests/perf --run",
    "m0f:test": "vitest run tests/m0f",
    "m0f:validate": "tsx m0f/cli.ts validate",
    "m0f:list": "tsx m0f/cli.ts list",
    "m0f:smoke": "tsx m0f/cli.ts smoke",
    "m0f:catalog-gate": "tsx m0f/cli.ts validate --complete",
    "m0f:gate": "tsx m0f/cli.ts gate",
    "m0f:bench": "npm run test:perf",
    "m0f:box-grid-candidates": "tsx m0f/box-grid-candidate-cli.ts",
    "m0f:box-grid-lattice": "tsx m0f/box-grid-lattice-cli.ts",
