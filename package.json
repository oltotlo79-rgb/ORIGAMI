    "m0f:ordered-tree-grid-candidates": "tsx m0f/ordered-tree-square-grid-candidate-cli.ts",
    "m0f:ordered-tree-path-demands": "tsx m0f/ordered-tree-path-demand-cli.ts",
    "m0f:polygon-river-packing-problem": "tsx m0f/polygon-river-packing-problem-cli.ts",
