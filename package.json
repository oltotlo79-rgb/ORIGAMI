    "m0f:neg-path-angle-knot-cardinality-candidate": "tsx m0f/neg-path-angle-knot-cardinality-candidate-bundle-cli.ts",
    "m0f:neg-path-duplicate-angle-crease-candidate": "tsx m0f/neg-path-duplicate-angle-crease-candidate-bundle-cli.ts",
    "m0f:neg-path-bound-knot-interval-cardinality-candidate": "tsx m0f/neg-path-bound-knot-interval-cardinality-candidate-bundle-cli.ts",
    "m0f:neg-path-duplicate-interval-bound-crease-candidate": "tsx m0f/neg-path-duplicate-interval-bound-crease-candidate-bundle-cli.ts",
    "m0f:neg-path-non-interior-motion-edge-candidate": "tsx m0f/neg-path-non-interior-motion-edge-candidate-bundle-cli.ts",
    "m0f:neg-path-polynomial-degree-range-candidate": "tsx m0f/neg-path-polynomial-degree-range-candidate-bundle-cli.ts",
    "m0f:neg-path-polynomial-coefficient-degree-candidate": "tsx m0f/neg-path-polynomial-coefficient-degree-candidate-bundle-cli.ts",
    "m0f:neg-path-polynomial-empty-coefficient-rows-candidate": "tsx m0f/neg-path-polynomial-empty-coefficient-rows-candidate-bundle-cli.ts",
    "m0f:neg-path-polynomial-non-finite-coefficient-candidate": "tsx m0f/neg-path-polynomial-non-finite-coefficient-candidate-bundle-cli.ts",
    "m0f:neg-path-polynomial-duplicate-coefficient-crease-candidate": "tsx m0f/neg-path-polynomial-duplicate-coefficient-crease-candidate-bundle-cli.ts",
    "m0f:neg-path-polynomial-duplicate-derivative-bound-crease-candidate": "tsx m0f/neg-path-polynomial-duplicate-derivative-bound-crease-candidate-bundle-cli.ts",
